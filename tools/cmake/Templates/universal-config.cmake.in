# @PACKAGE_NAME@-config.cmake -- package configuration for the
# Universal Numbers Library (https://github.com/stillwater-sc/universal).
#
# Consume with:
#
#   find_package(@PACKAGE_NAME@ CONFIG REQUIRED)
#   target_link_libraries(my_target PRIVATE @PACKAGE_NAME@::@project_library_target_name@)
#
# Universal is a header-only C++20 library. Linking the imported target
# propagates the include directory and the C++20 compile feature without
# modifying the consumer's CMAKE_CXX_STANDARD or other global state.
#
# Exposed result variables (for consumers that have not migrated to the
# imported-target style):
#   @PACKAGE_NAME@_FOUND        - TRUE when found
#   @PACKAGE_NAME@_INCLUDE_DIRS - include directory
#   @PACKAGE_NAME@_LIBRARIES    - imported target
#   @PACKAGE_NAME@_VERSION      - version string (set by CMake from *-config-version.cmake)
#
# Exposed imported target:
#   @PACKAGE_NAME@::@project_library_target_name@

if(@PACKAGE_NAME@_CONFIG_INCLUDED)
  return()
endif()
set(@PACKAGE_NAME@_CONFIG_INCLUDED TRUE)

@PACKAGE_INIT@

if(NOT TARGET @PACKAGE_NAME@::@project_library_target_name@)
  include("${CMAKE_CURRENT_LIST_DIR}/@cmake_targets_file@")
endif()

# Backwards-compatible convenience variables.
set(@PACKAGE_NAME@_LIBRARIES    @PACKAGE_NAME@::@project_library_target_name@)
set(@PACKAGE_NAME@_INCLUDE_DIRS "@PACKAGE_include_install_dir_full@")

set(@PACKAGE_NAME@_FOUND TRUE)
